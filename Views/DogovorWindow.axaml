<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:model="using:Tipografia3.Models"
        mc:Ignorable="d"
        d:DesignWidth="400"
        d:DesignHeight="450"
        x:Class="Tipografia3.Views.DogovorWindow"
        Title="Договор"
        Width="400"
        Height="450"
        WindowStartupLocation="CenterOwner"
        x:DataType="model:Dogovor">

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<TextBlock Grid.Row="0" Text="Номер договора:" Margin="0,5"/>
		<TextBox Grid.Row="1" Text="{Binding NumberDogovor}" Margin="0,5"/>

		<TextBlock Grid.Row="2" Text="Клиент:" Margin="0,5"/>
		<ComboBox Grid.Row="3"
				 x:Name="ClientComboBox"
				 ItemsSource="{Binding $parent[Window].Clients}"
				 SelectedValueBinding="{Binding IdClient}"
				 DisplayMemberBinding="{Binding NameClient}"
				 PlaceholderText="Выберите клиента"
				 HorizontalAlignment="Stretch"
				 Margin="0,5"/>

		<TextBlock Grid.Row="4" Text="Дата оформления:" Margin="0,5"/>
		<DatePicker Grid.Row="5" x:Name="DateOformlPicker" Margin="0,5"/>

		<TextBlock Grid.Row="6" Text="Дата выполнения:" Margin="0,5"/>
		<DatePicker Grid.Row="7" x:Name="DateDuePicker" Margin="0,5"/>

		<StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
			<Button Content="Сохранить" Width="100" Margin="10" Click="Save_Click"/>
			<Button Content="Отменить" Width="100" Margin="10" Click="Cancel_Click"/>
		</StackPanel>
	</Grid>
</Window>