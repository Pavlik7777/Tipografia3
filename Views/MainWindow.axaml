<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Tipografia3.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        x:Class="Tipografia3.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        xmlns:converters="clr-namespace:Tipografia3.Converters"
        Title="{Binding Title}"
        Width="1000" Height="600">


	<Design.DataContext>
		<vm:MainWindowViewModel/>
	</Design.DataContext>

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="200"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<!-- Левая панель навигации -->
		<Border Grid.Column="0" Background="Pink" Padding="5" >
			<StackPanel Spacing="5">
				<TextBlock Text="ТИПОГРАФИЯ"
                           FontSize="18"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,20"
                           Foreground="#333"/>

				<Button Content="Главная"
                        Width="180"
                        Height="40"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Home"
                        Background="white"/>

				<Button Content="Цеха"
                        Width="180"
                        Height="40"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Ceh"
                        Background="white"/>

				<Button Content="Продукция"
                        Width="180"
                        Height="40"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Product"
                        Background="white"/>

				<Button Content="Договоры"
                        Width="180"
                        Height="40"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Dogovor"
                        Background="white"/>

				<Button Content="Заказы"
                        Width="180"
                        Height="40"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Order"
                        Background="white"/>

				<Button Content="Отчёты"
                        Width="180"
                        Height="40"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Reports"
                        Background="white"/>

				<Button Content="Графики"
                        Width="180"
                        Height="40"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Charts"
                        Background="white"/>
			</StackPanel>
		</Border>

		<!-- Основная область контента -->
		<Border Background="White"
                Padding="15"
                Grid.Column="1"
                BorderBrush="#CCCCCC"
                BorderThickness="1,0,0,0">
			<ContentControl Content="{Binding CurrentPage}"/>
		</Border>
	</Grid>
</Window>
