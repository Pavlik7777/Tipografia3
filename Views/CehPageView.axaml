<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Tipografia3.ViewModels"
             xmlns:model="using:Tipografia3.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Tipografia3.Views.CehPageView"
             x:DataType="vm:CehPageViewModel">

	<Design.DataContext>
		<vm:CehPageViewModel/>
	</Design.DataContext>

	<UserControl.Resources>
		<DataTemplate x:Key="CehTemplate" DataType="model:TipografCeh">
			<Border BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="5">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="80"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
						<!-- ← Auto вместо фиксированной -->
						<ColumnDefinition Width="Auto"/>
						<!-- ← Auto вместо фиксированной -->
					</Grid.ColumnDefinitions>
					<TextBlock Grid.Column="0" Text="{Binding NumberCeh}" FontWeight="Bold"/>
					<TextBlock Grid.Column="1" Text="{Binding NameCeh}" Margin="0,0,20,0"/>
					<!-- ← отступ справа -->
					<TextBlock Grid.Column="2" Text="{Binding BossCeh}" Margin="0,0,30,0"/>
					<!-- ← отступ от телефона -->
					<TextBlock Grid.Column="3" Text="{Binding PhoneCeh}"/>
				</Grid>
			</Border>
		</DataTemplate>
	</UserControl.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Заголовок -->
		<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
			<TextBlock Text="Цеха типографии"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="0,0,20,0"/>
			<Button Content="📥 Импорт" Command="{Binding ImportCommand}" Margin="5,0"/>
			<Button Content="📤 Экспорт" Command="{Binding ExportCommand}" Margin="5,0"/>
		</StackPanel>

		<!-- Список -->
		<Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" Margin="5">
			<ScrollViewer>
				<ListBox ItemsSource="{Binding Cehs}"
                         ItemTemplate="{StaticResource CehTemplate}"
                         SelectedItem="{Binding SelectedCeh}"/>
			</ScrollViewer>
		</Border>

		<!-- Кнопки -->
		<StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5">
			<Button Content="➕ Добавить" Command="{Binding AddCommand}" Margin="5"/>
			<Button Content="✏️ Редактировать" Command="{Binding EditCommand}" Margin="5"/>
			<Button Content="🗑️ Удалить" Command="{Binding DeleteSelectedCommand}" Margin="5"/>
		</StackPanel>
	</Grid>
</UserControl>