<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Tipografia3.ViewModels"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Tipografia3.Views.ChartsPageView"
             x:DataType="vm:ChartsPageViewModel">

	<Design.DataContext>
		<vm:ChartsPageViewModel/>
	</Design.DataContext>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
			<TextBlock Text="Графики и диаграммы"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="0,0,20,0"/>
			<Button Content="🔄 Обновить"
                    Command="{Binding LoadChartsCommand}"
                    Margin="5,0"/>
		</StackPanel>

		<TabControl Grid.Row="1" Margin="10">

			<!-- 1. Столбчатая диаграмма — Заказы по цехам -->
			<TabItem Header="Заказы по цехам">
				<Grid RowDefinitions="Auto,*">

					<Button Grid.Row="0"
							Content="💾 Сохранить PNG"
							Click="SaveOrdersByCehChart_Click"/>

					<lvc:CartesianChart
						Grid.Row="1"
						x:Name="OrdersByCehChart"
						Series="{Binding OrdersByCehSeries}"
						XAxes="{Binding OrdersByCehXAxes}" />

				</Grid>
			</TabItem>

			<!-- 2. Круговая диаграмма — Доля по продукции -->
			<TabItem Header="Доля по продукции">
				<Grid RowDefinitions="Auto,*">

					<Button Grid.Row="0"
							Content="💾 Сохранить PNG"
							HorizontalAlignment="Left"
							Margin="5"
							Click="SaveOrdersByProductChart_Click"/>

					<lvc:PieChart
						Grid.Row="1"
						x:Name="OrdersByProductChart"
						Margin="10"
						Series="{Binding OrdersByProductSeries}"
						LegendPosition="Right"/>

				</Grid>
			</TabItem>

			<!-- 3. Линейный график — Динамика по месяцам -->
			<TabItem Header="Динамика по месяцам">
				<Grid RowDefinitions="Auto,*">

					<Button Grid.Row="0"
							Content="💾 Сохранить PNG"
							HorizontalAlignment="Left"
							Margin="5"
							Click="SaveOrdersByMonthChart_Click"/>

					<lvc:CartesianChart
						Grid.Row="1"
						x:Name="OrdersByMonthChart"
						Margin="10"
						Series="{Binding OrdersByMonthSeries}"
						XAxes="{Binding OrdersByMonthXAxes}" />

				</Grid>
			</TabItem>

			<!-- 4. Гистограмма — Распределение стоимости -->
			<TabItem Header="Распределение стоимости">
				<Grid RowDefinitions="Auto,*">

					<Button Grid.Row="0"
							Content="💾 Сохранить PNG"
							HorizontalAlignment="Left"
							Margin="5"
							Click="SavePriceDistributionChart_Click"/>

					<lvc:CartesianChart
						Grid.Row="1"
						x:Name="PriceDistributionChart"
						Margin="10"
						Series="{Binding PriceDistributionSeries}"
						XAxes="{Binding PriceDistributionXAxes}" />

				</Grid>
			</TabItem>

		</TabControl>
	</Grid>
</UserControl>
